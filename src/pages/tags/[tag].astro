---
import BaseLayout from "../../layouts/BaseLayout.astro";
import BlogPost from "../../components/BlogPost.astro";

// A getStaticPaths function should always return a list of objects containing params (what to call each page route) and optionally any props (data that you want to pass to those pages).
// For any dynamic route file (a filename with [brackets], like [tag].astro), Astro requires you to export a function named getStaticPaths.
// Astro's internal router imports that module and invokes getStaticPaths() itself, during the build (or on-demand in dev) — before it ever renders the component.
// It uses the returned array of { params, props } objects to know which static pages to generate (e.g. /tags/astro, /tags/community, etc.) and
// what Astro.params/Astro.props to inject into each one.
export async function getStaticPaths() {
  const allPosts = Object.values(
    import.meta.glob("../posts/*.md", { eager: true }),
  );
  const uniqueTags = [...new Set(allPosts.flatMap((post: any) => post.frontmatter.tags ?? []))];

  return uniqueTags.map((tag) => ({
    params: { tag },
    props: {
      posts: allPosts.filter((post: any) => post.frontmatter.tags?.includes(tag)),
      title: `Posts tagged with ${tag}`,
    },
  }));
}

const { tag } = Astro.params;
const { posts, title } = Astro.props;
---

<BaseLayout pageTitle={title}>
  <p>{title}</p>
  <ul>
    {posts.map((post: any) => <BlogPost url={post.url} title={post.frontmatter.title}/>)}
  </ul>
</BaseLayout>
