{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Astro Dev Server",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "node",
      "runtimeArgs": ["--inspect", "./node_modules/.bin/astro", "dev"],
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"],
      "sourceMaps": true,
      "serverReadyAction": {
        "action": "debugWithChrome",
        "pattern": "astro\\s+v?[0-9.]+ ready in",
        "uriFormat": "http://localhost:4321"
      }
    }
  ]
}
